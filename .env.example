# Groq API key (free tier): https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the Groq model (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: a webhook.site or Pipedream URL to actually receive the mock
# booking-confirmation notification. If unset, the notification is simulated
# locally and just returned as JSON.
# WEBHOOK_NOTIFY_URL=
